# Job Automation Agent - Environment Configuration
# Copy this file to .env and fill in your values

# Application
DEBUG=false

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/job_automation

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Gmail OAuth2 (for email tracking)
# Create OAuth credentials at https://console.cloud.google.com/
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/api/auth/gmail/callback

# Agent Schedules
SCOUT_INTERVAL_HOURS=6
ANALYST_INTERVAL_MINUTES=30
TRACKER_INTERVAL_MINUTES=60
APPLICANT_INTERVAL_MINUTES=15

# Application Thresholds
MIN_MATCH_SCORE_FOR_AUTO_APPLY=60
MAX_APPLICATIONS_PER_DAY=50

# Cost Management
MAX_DAILY_API_COST=5.0

# Server
HOST=0.0.0.0
PORT=8000
