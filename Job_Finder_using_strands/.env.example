# ---- LLM provider (pick one; Gemini is default + cheapest for this workload) ----
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Claude fallback
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenAI fallback
# OPENAI_API_KEY=sk-...

# ---- App settings ----
LLM_PROVIDER=gemini
LLM_MODEL_ID=gemini-2.5-flash
MATCH_THRESHOLD=0.65
MAX_JOBS_PER_COMPANY=20

# ---- Your defaults for form filling (used by the Applicator agent) ----
APPLICANT_FIRST_NAME=Vignesh
APPLICANT_LAST_NAME=Chinnadurai
APPLICANT_EMAIL=your.email@example.com
APPLICANT_PHONE=+91-9999999999
APPLICANT_LOCATION=Bangalore, India
APPLICANT_LINKEDIN=https://linkedin.com/in/your-profile
APPLICANT_GITHUB=https://github.com/your-handle
APPLICANT_PORTFOLIO=
RESUME_PATH=data/resume.pdf
